{% extends "base.njk" %}

{% block breadcrumb %}
<nav class="breadcrumb" aria-label="Breadcrumb">
    <span class="breadcrumb-current">API Reference</span>
</nav>
{% endblock %}

{% block content %}
<div class="page-header">
    <h1 style="font-family: var(--font-sans); font-size: 1.875rem;">Hammerspoon 2 API Documentation</h1>
    <span class="page-badge">Reference</span>
</div>

<p style="color: var(--text-secondary); font-size: 0.9375rem; margin-bottom: 2rem; line-height: 1.65;">
    Welcome to the Hammerspoon 2 API reference. Browse modules for top-level functionality, or explore types for object APIs.
</p>

<h2 class="section-heading">Modules</h2>
<p style="color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 0.75rem;">
    Modules are the main entry points for Hammerspoon functionality, accessible via the <code>hs</code> global.
</p>
<div class="grid">
    {% for module in modules %}
    <a href="{{ module.name }}.html" class="card">
        <h3>{{ module.name }}</h3>
        <p>{{ module.swiftProtocols }} protocols · {{ module.javascriptFunctions }} functions</p>
    </a>
    {% endfor %}
</div>

<h2 class="section-heading">Types</h2>
<p style="color: var(--text-secondary); font-size: 0.875rem; margin-bottom: 0.75rem;">
    Types represent objects that can be created and manipulated in Hammerspoon scripts.
</p>
<div class="grid">
    {% for type in types %}
    <a href="{{ type }}.html" class="card">
        <h3>{{ type }}</h3>
    </a>
    {% endfor %}
</div>
{% endblock %}
